rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Common functions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == "dabin_0408@naver.com"; 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Everyone can see projects
      
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.category in ["공공디자인", "브랜딩디자인", "시각디자인", "인테리어디자인", "행사디자인"]
        && data.thumbnail is string && data.thumbnail.size() > 0
        && (data.images == null || data.images is list);
    }
  }
}
