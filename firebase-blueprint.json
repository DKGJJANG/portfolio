{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "subtitle": { "type": "string", "description": "Project subtitle" },
        "category": { "type": "string", "description": "One of the 5 categories" },
        "thumbnail": { "type": "string", "description": "Main thumbnail image URL" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Additional project images" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["title", "subtitle", "category", "thumbnail", "images", "createdAt", "authorUid"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects"
    }
  }
}
