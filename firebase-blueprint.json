{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A design project in the portfolio",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["공공디자인", "브랜딩디자인", "시각디자인", "인테리어디자인", "행사디자인"] },
        "thumbnail": { "type": "string" },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "caption": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "thumbnail"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all projects"
    }
  }
}
